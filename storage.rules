rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if false;
    }
    
    // Receipts storage
    match /receipts/{receiptId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Product images
    match /product_images/{productId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
